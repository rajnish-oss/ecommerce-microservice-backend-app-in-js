generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model cart{
  cartId Int @id
  cartItem cartItem[]
}

model cartItem{
  productId Int
  name      String
  price     Int
  category  String
  quantity     Int
  cart cart @relation(fields: [cartId], references: [cartId])
  cartId    Int 
  isAvailable Boolean @default(true)


  @@id([cartId, productId])
}
