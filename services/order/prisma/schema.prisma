generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model orderList {
  userId Int @id
  orders order[]
}

model order {
  productId Int
  status OrderStatus
  quantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderList orderList @relation(fields: [listId], references: [userId])
  listId Int

  @@id([listId, productId])
}

enum OrderStatus{
  PENDING 
  COMPLETED 
  CANCELLED 
  SHIPPED
}

